# CADEX DIGEST.log — structured task delta chain
# Replaces prose summaries entirely. Every completed task emits one JSON delta block.
# Agent loads: last 7 deltas at session start.
# Volatile execution entries auto-expire after 5 sessions unless promoted to DECISIONS.log.
#
# DELTA TYPES:
#   state_delta     — decision made, requirement changed, convention updated
#   artifact_delta  — file/symbol added, edited, deleted, renamed
#   execution_delta — test result, bug found, command run, result observed
#   intent_delta    — what the task actually accomplished (human-readable)
#
# CHANGE values for artifact_delta:
#   added | edited | deleted | renamed | refactored
#
# CONFIDENCE for state_delta entries:
#   confirmed | provisional | speculative
#
# After completing a task, the agent appends ONE block below.
# Never edit past blocks — append only.

# ─────────────────────────────────────────────────────────
# SCHEMA
# ─────────────────────────────────────────────────────────
# {
#   "task_id": "T-NNN",
#   "date": "YYYY-MM-DD",
#   "mode": "bugfix | feature | refactor | design | docs",
#   "intent_delta": "one sentence — what this task accomplished",
#   "artifact_delta": [
#     {"file": "path/to/file.ts", "symbol": "FunctionName", "hash": "sha256:8chars", "change": "edited"}
#   ],
#   "state_delta": [
#     {"type": "decision|convention|requirement", "value": "...", "confidence": "confirmed", "source": "test|user|code|discussion", "last_verified_at": "YYYY-MM-DD"}
#   ],
#   "execution_delta": [
#     {"type": "test|bug|command|observation", "value": "...", "volatile": true}
#   ],
#   "next_pointer": ["path/to/file.ts#SymbolName"],
#   "open_loops_opened": ["OL-NNN"],
#   "open_loops_resolved": ["OL-NNN"],
#   "session_tokens_used": 000
# }

# ─────────────────────────────────────────────────────────
# EXAMPLE ENTRIES (delete and replace with your own)
# ─────────────────────────────────────────────────────────

